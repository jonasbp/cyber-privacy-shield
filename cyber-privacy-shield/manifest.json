{
  "manifest_version": 2,
  "name": "Privacy Shield - Detector de Rastreadores",
  "version": "1.0.0",
  "description": "Detecta rastreadores, cookies, fingerprinting e ameaças de privacidade em tempo real.",
  "author": "Avaliação Intermediária - Cybersegurança",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Privacy Shield"
  },

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "tabs",
    "storage",
    "cookies",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["lists/trackers.js", "background/background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    "content/injected.js"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "privacy-shield@cybersec",
      "strict_min_version": "57.0"
    }
  }
}
